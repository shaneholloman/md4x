{
  "name": "md4x",
  "version": "0.0.18",
  "repository": "pi0/md4x",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./wasm": {
      "types": "./lib/wasm/index.d.mts",
      "unwasm": "./lib/wasm/unwasm.mjs",
      "default": "./lib/wasm/defult.mjs"
    },
    "./napi": "./lib/napi.mjs",
    "./build/md4x.wasm": "./build/md4x.wasm",
    ".": {
      "node": "./lib/napi.mjs",
      "default": {
        "unwasm": "./lib/wasm/unwasm.mjs",
        "default": "./lib/wasm/defult.mjs"
      }
    }
  },
  "types": "./lib/types.d.mts",
  "bin": {
    "md4x": "./lib/cli.mjs"
  },
  "files": [
    "build",
    "lib",
    "README.md"
  ],
  "scripts": {
    "prepack": "cd ../.. && zig build --verbose"
  },
  "devDependencies": {
    "markdown-it": "^14.1.1",
    "markdown-it-mdc": "^0.2.12",
    "md4w": "^0.2.7",
    "mitata": "^1.0.34"
  }
}
